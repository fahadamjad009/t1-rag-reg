# Retrieval
RAG_MIN_SCORE=0.25
TOP_K=5
DATA_DIR=data
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Indexing (scripts/build_index_from_corpus.py)
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# Fail-closed behaviour (app/main.py)
STRICT_FAIL_CLOSED=true
MIN_CALIB_CONF=0.35
MIN_EXTRACTIVE_CONF=0.15

# Refusal HTTP status: 200 = PowerShell-friendly (semantic status in body),
# set to 424 for strict HTTP semantics
REFUSAL_HTTP_STATUS=200
